# Environment Configuration Example
# Copy this to .env and update values for your environment

# Environment
NODE_ENV=development
PORT=3000

# JWT Configuration
# Use strong random strings in production!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_12345

# Token Expiration Times
# Format: e.g., 15m, 1h, 7d
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# Database Configuration
# Currently using mock database, replace with MongoDB/PostgreSQL URI
DATABASE_URL=http://localhost:27017/ai-genius

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
